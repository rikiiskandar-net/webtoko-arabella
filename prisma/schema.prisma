// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductBadge {
  Promo
  Bestseller
  Baru
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
}

enum AdminRole {
  superadmin
  admin
}

/// Setup storage bucket via migration hook

model Category {
  id          String    @id @default(uuid())
  name        String
  icon        String    // We'll store the Lucide icon name here
  description String    @default("")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([name])
}

model Admin {
  id             String          @id @default(uuid())
  username       String          @unique
  password       String
  name           String
  role           AdminRole       @default(admin)
  isActive       Boolean         @default(true)
  baseWage       Int             @default(120000)
  payrollPeriods PayrollPeriod[]
  attendances    Attendance[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model StoreConfig {
  id             String   @id @default(uuid())
  isOpen         Boolean  @default(true)
  storeName      String   @default("Dapur Arabella")
  waNumber       String   @default("")
  description    String   @default("")
  address        String   @default("")
  hours          String   @default("Tutup pukul 21.00")
  deliveryETA    String   @default("Antar mulai 15 menit")
  instagram      String   @default("")
  facebook       String   @default("")
  email          String   @default("")
  paymentMethods String   @default("BCA, Mandiri, GoPay, OVO, ShopeePay")
  aboutTitle     String   @default("Berawal dari Camilan Sehat untuk Anak")
  aboutDescription String @default("Dapur Arabella memang baru seumur jagung, tapi kecintaan kami pada masakan rumahan sudah ada sejak lama. Semuanya berawal dari hobi memasak dan keisengan membuatkan camilan sore yang aman untuk anak-anak di rumah. Ternyata, saat tetangga ikut mencicipi, mereka sangat menyukainya dan mulai ikut memesan!\n\nDari dorongan merekalah Dapur Arabella akhirnya lahir. Karena pada dasarnya masakan ini kami buat untuk keluarga sendiri, kami sangat cerewet soal kebersihan dan pantang menggunakan bahan pengawet.")
  aboutPoints    String   @default("Tanpa Bahan Pengawet,Bahan Bumbu Pilihan,Kebersihan Terjamin,Dibuat Terbatas (Fresh)")
  aboutBadgeNumber String @default("100%")
  aboutBadgeText String   @default("Buatan\nTangan")
  aboutImage     String   @default("/images/about_us.jpg")
  updatedAt      DateTime @updatedAt
}

model HeroBanner {
  id        String   @id @default(uuid())
  image     String
  badge     String   @default("")
  title     String
  subtitle  String   @default("")
  ctaText   String   @default("Eksplor Menu Sekarang")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerPhone String      @default("")
  address       String
  notes         String      @default("")
  items         Json        @default("[]")
  totalPrice    Int
  status        OrderStatus @default(pending)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@index([userId])
}

model Product {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  price         Int
  description   String
  image         String
  images        Json?       @default("[]")
  variants      Json?       @default("[]")
  isPromo       Boolean     @default(false)
  isWebDiscountable Boolean @default(true)
  promoPrice    Int?
  originalPrice Int?
  badge         String?
  rating        Float       @default(0)
  sold          String      @default("0")
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  cartItems     CartItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reviews       ProductReview[]

  @@index([categoryId])
  @@index([isPromo])
  @@index([badge])
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 1 to 5
  comment   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  country   String   @default("Unknown")
  browser   String   @default("Unknown")
  os        String   @default("Unknown")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String   @default("")
  address   String   @default("")
  avatar    String   @default("")
  isActive  Boolean  @default(true)
  cart      Cart?
  reviews   ProductReview[]
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  variants  Json?    @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
}

enum CashType {
  income
  expense
}

model CashEntry {
  id          String   @id @default(uuid())
  type        CashType
  amount      Int
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([type])
}

model PayrollPeriod {
  id          String       @id @default(uuid())
  adminId     String
  admin       Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime?
  isClosed    Boolean      @default(false)
  totalAmount Int          @default(0)
  attendances Attendance[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([adminId])
  @@index([isClosed])
}

model Attendance {
  id              String        @id @default(uuid())
  payrollPeriodId String
  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  adminId         String
  admin           Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  date            DateTime      @db.Date
  status          String
  baseWage        Int           @default(120000)
  multiplier      Float         @default(1.0)
  extraPay        Int           @default(0)
  totalPay        Int
  notes           String        @default("")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([adminId, date])
  @@index([payrollPeriodId])
  @@index([date])
}

// ==========================================
// PROJECT WORKER ATTENDANCE SYSTEM
// ==========================================

model Worker {
  id             String                @id @default(uuid())
  email          String                @unique
  password       String                // Can be a PIN hash
  name           String
  role           String                @default("Pekerja")
  phone          String?
  address        String?
  isActive       Boolean               @default(true)
  baseWage       Int                   @default(100000)
  payrollPeriods WorkerPayrollPeriod[]
  attendances    WorkerAttendance[]
  cashbons       WorkerCashbon[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model WorkerPayrollPeriod {
  id          String             @id @default(uuid())
  workerId    String
  worker      Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime?
  isClosed    Boolean            @default(false)
  totalAmount Int                @default(0)
  attendances WorkerAttendance[]
  cashbons    WorkerCashbon[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([workerId])
  @@index([isClosed])
}

model WorkerAttendance {
  id              String              @id @default(uuid())
  payrollPeriodId String
  payrollPeriod   WorkerPayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  workerId        String
  worker          Worker              @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date            DateTime            @db.Date
  status          String
  baseWage        Int                 @default(100000)
  multiplier      Float               @default(1.0)
  extraPay        Int                 @default(0)
  totalPay        Int
  notes           String              @default("")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([workerId, date, payrollPeriodId])
  @@index([payrollPeriodId])
  @@index([date])
}

model WorkerCashbon {
  id              String              @id @default(uuid())
  payrollPeriodId String
  payrollPeriod   WorkerPayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  workerId        String
  worker          Worker              @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date            DateTime            @db.Date
  amount          Int
  reason          String              @default("")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([payrollPeriodId])
  @@index([workerId])
  @@index([date])
}

// ==========================================
// PENGELOLA AKUN (ACCOUNT MANAGER)
// ==========================================

model AccountCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String   @default("Folder")
  accounts  AccountCredential[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccountCredential {
  id          String   @id @default(uuid())
  categoryId  String
  category    AccountCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title       String
  username    String
  password    String   @db.Text
  url         String?  @default("")
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
}
